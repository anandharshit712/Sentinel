{
    # NVIDIA NIM. Included by registries/sentinel.hocon (04 §6.1). Providers without keys are culled.
    # `fallbacks` are tried in order and fallbacks[0] is the effective primary — the top-level
    # `model_name` override does NOT reorder them (verified in B1: with 70B first the network timed
    # out even with MODEL_NAME set). So the WORKING dev model goes first.
    "fallbacks": [
        # Working dev primary: mistral, form B = class:nvidia + RAW NIM id (a bare key with class -> 404). (rule 3)
        { "class": "nvidia", "model_name": "mistralai/mistral-small-4-119b-2603", "temperature": 0.1 },
        # Documented primary once access exists — currently times out on the public NIM endpoint.
        { "class": "nvidia", "model_name": "meta/llama-3.3-70b-instruct", "temperature": 0.1 },
        { "model_name": ${?FALLBACK_MODEL_NAME} }     # optional 2nd provider (gpt-4o / claude); ignored if unset
    ],
    "model_name": ${?MODEL_NAME}                       # whole-network override, wins when set
}
