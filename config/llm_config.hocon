{
    # Primary: NVIDIA NIM. Providers without keys are culled automatically.
    # Included by registries/sentinel.hocon. (04 §6.1)
    "fallbacks": [
        # Form B: class:nvidia + RAW NIM id (a bare model key with class is sent unmapped -> 404). (rule 3)
        # 70B is documented primary but times out on public NIM; MODEL_NAME=nvidia-mistral-small-4-119b overrides.
        { "class": "nvidia", "model_name": "meta/llama-3.3-70b-instruct", "temperature": 0.1 },
        { "model_name": ${?FALLBACK_MODEL_NAME} }     # e.g. gpt-4o / claude-sonnet; line ignored if unset
    ],
    "model_name": ${?MODEL_NAME}                       # whole-network override, wins when set
}
