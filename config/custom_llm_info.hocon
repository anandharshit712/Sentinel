{
    # NIM model registry, wired via AGENT_LLM_INFO_FILE. (04 §6.2)
    # Pattern (from neuro-san default_llm_info.hocon): a friendly ALIAS key whose `use_model_name`
    # points to ANOTHER KEY that is fully specified — and that key's NAME is the raw NIM model id.
    # (use_model_name is an alias-to-key, NOT a raw id; pointing it straight at a raw id -> "No llm entry". Spike 0.4.)

    # Right-sizing slot: lighter NIM model for code_quality_agent / environment_context_agent
    # when LIGHT_MODEL_NAME=nvidia-llama-3.1-8b-instruct is set.
    "nvidia-llama-3.1-8b-instruct": { "use_model_name": "meta/llama-3.1-8b-instruct" },
    "meta/llama-3.1-8b-instruct":   { "class": "nvidia", "max_output_tokens": 8192 },

    # Working stand-in for the locked 70B (which times out on the public endpoint). 119B, fast, tool-calls.
    "nvidia-mistral-small-4-119b":         { "use_model_name": "mistralai/mistral-small-4-119b-2603" },
    "mistralai/mistral-small-4-119b-2603": { "class": "nvidia", "max_output_tokens": 8192 }
}
