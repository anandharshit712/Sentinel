# Sentinel local test override — run studio samples on NVIDIA NIM (mistral) instead of OpenAI.
# Reference-clone edit (CLAUDE.md read-only rule); user-requested, reversible:
#   git -C neuro-san-studio checkout config/llm_config.hocon
# Form that resolves correctly for NIM in neuro-san: class:nvidia + the RAW model id
# (a bare model key passed with class is sent unmapped -> 404).
{
    "llm_config": {
        "fallbacks": [
            { "class": "nvidia", "model_name": "mistralai/mistral-small-4-119b-2603", "temperature": 0.1 }
        ]
    }
}
